<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 我的UID -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/my_info"
            android:textSize="18sp"
            android:textColor="@color/accent"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/my_uid"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tv_my_uid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/loading"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:background="@color/input_background"
            android:padding="8dp"
            android:layout_marginBottom="16dp"
            android:textIsSelectable="true" />

        <!-- 我的公钥 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/my_public_key"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/input_background"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_my_pub_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/loading"
                android:textSize="11sp"
                android:textColor="@color/text_primary"
                android:fontFamily="monospace"
                android:padding="8dp"
                android:textIsSelectable="true" />
        </ScrollView>

        <Button
            android:id="@+id/btn_copy_pub_key"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/copy_public_key"
            android:backgroundTint="@color/btn_background"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- 重新生成密钥 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="危险操作"
            android:textSize="18sp"
            android:textColor="@color/accent_red"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_regenerate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/regenerate_keys"
            android:backgroundTint="@color/accent_red"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</ScrollView>
