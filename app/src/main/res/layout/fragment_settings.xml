<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="12dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== 主题 ===== -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🎨 主题" android:textSize="13sp" android:textColor="#888"
            android:layout_marginBottom="4dp" android:layout_marginStart="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#222" android:padding="12dp"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="深色模式" android:textSize="15sp" />
                <Switch android:id="@+id/switch_dark" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== 我的信息 ===== -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🔑 我的信息" android:textSize="13sp" android:textColor="#888"
            android:layout_marginBottom="4dp" android:layout_marginStart="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#222" android:padding="12dp"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="我的 UID" android:textSize="12sp" android:textColor="#888" />
            <TextView android:id="@+id/tv_my_uid" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:fontFamily="monospace" android:padding="4dp" android:layout_marginBottom="8dp"
                android:textIsSelectable="true" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="公钥 (Base64)" android:textSize="12sp" android:textColor="#888" />
            <HorizontalScrollView android:layout_width="match_parent"
                android:layout_height="80dp" android:layout_marginBottom="8dp">
                <TextView android:id="@+id/tv_my_pub_key" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textSize="11sp"
                    android:fontFamily="monospace" android:padding="8dp" android:textIsSelectable="true" />
            </HorizontalScrollView>
            <Button android:id="@+id/btn_copy_pub_key" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="复制公钥（给别人加我）"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ===== 账户管理 ===== -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚙️ 账户管理" android:textSize="13sp" android:textColor="#888"
            android:layout_marginBottom="4dp" android:layout_marginStart="4dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#222" android:padding="12dp"
            android:layout_marginBottom="16dp">
            <Button android:id="@+id/btn_export_priv" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="导出私钥（备份）" android:textSize="13sp"
                android:layout_marginBottom="6dp" />
            <Button android:id="@+id/btn_import_account" android:layout_width="match_parent"
                android:layout_height="40dp" android:text="导入私钥（恢复账户）" android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
